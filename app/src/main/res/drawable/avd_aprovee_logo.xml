<?xml version="1.0" encoding="utf-8"?>
<animated-vector
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">

    <aapt:attr name="android:drawable">
        <vector
            android:width="100dp"
            android:height="100dp"
            android:viewportWidth="100"
            android:viewportHeight="100">

            <!-- A simétrico (duas pernas num traço só) -->
            <path
                android:name="letterA"
                android:fillColor="#00000000"
                android:strokeColor="#FFFFFF"
                android:strokeWidth="10"
                android:strokeLineCap="round"
                android:strokeLineJoin="round"
                android:trimPathEnd="0"
                android:pathData="M30,74 L50,26 L70,74" />

            <!-- Check centralizado que fecha o A -->
            <path
                android:name="check"
                android:fillColor="#00000000"
                android:strokeColor="#FFFFFF"
                android:strokeWidth="9"
                android:strokeLineCap="round"
                android:strokeLineJoin="round"
                android:trimPathEnd="0"
                android:pathData="M37,57 L47,66 L64,45" />
        </vector>
    </aapt:attr>

    <!-- A desenha primeiro (perna esq → ápice → perna dir, num traço) -->
    <target android:name="letterA">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:valueFrom="0"
                android:valueTo="1"
                android:duration="450"
                android:startOffset="0"
                android:interpolator="@android:interpolator/fast_out_slow_in" />
        </aapt:attr>
    </target>

    <!-- Check só começa depois que o A termina (offset 450) -->
    <target android:name="check">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:valueFrom="0"
                android:valueTo="1"
                android:duration="300"
                android:startOffset="450"
                android:interpolator="@android:interpolator/fast_out_slow_in" />
        </aapt:attr>
    </target>
</animated-vector>
