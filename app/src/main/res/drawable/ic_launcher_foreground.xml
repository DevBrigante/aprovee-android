<!-- Marca Aprovee: A simétrico fechado por um check, em branco sobre o fundo teal.
     Mesma geometria do logo da splash (avd_aprovee_logo), porém estático.
     Conteúdo centralizado dentro da safe zone do adaptive icon (scale 0.9 + translate). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group
        android:pivotX="50"
        android:pivotY="50"
        android:scaleX="0.9"
        android:scaleY="0.9"
        android:translateX="4"
        android:translateY="4">

        <!-- A simétrico (duas pernas) -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="10"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:pathData="M30,74 L50,26 L70,74" />

        <!-- Check que fecha o A -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="9"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:pathData="M37,57 L47,66 L64,45" />
    </group>
</vector>
